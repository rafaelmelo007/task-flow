# Copy to .env and fill in your values
# Never commit .env to source control

# JWT — must be >= 32 characters
Jwt__Secret=REPLACE_ME_WITH_A_STRONG_SECRET_AT_LEAST_32_CHARS

# CORS — comma-separated origins
Cors__AllowedOrigins=http://localhost:4200

# Connection string (SQLite default)
ConnectionStrings__DefaultConnection=Data Source=taskflow.db

# Seed demo data on startup
Seed__Enabled=true
